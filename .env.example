# ETF Radar example environment. Copy to .env on the server and fill secrets locally.
API_TOKEN=change-me
WEB_AUTH_ENABLED=true
WEB_USERNAME=admin
WEB_PASSWORD_HASH=
WEB_SESSION_SECRET=change-me

POLL_INTERVAL_SECONDS=30
API_POLLING_ENABLED=false
COLLECTOR_REFRESH_HISTORY_ON_START=true
HISTORY_REFRESH_EVERY_TICKS=10
DATA_STALE_SECONDS=90
DATABASE_PATH=/opt/etf-radar/data/etf_radar.sqlite3

MAIN_ETF_CODES=513120,159516
BACKUP_ETF_CODES=515880
BENCHMARK_CODES=510300,588000
DISCOVERY_CACHE_SECONDS=30
DISCOVERY_MIN_AMOUNT=50000000
DISCOVERY_MAX_DIRECTIONS=8
STOCK_FOCUS_ENABLED=true

AI_ENABLED=false
AI_SUMMARY_DAILY_CALL_LIMIT=4
AI_SUMMARY_FORCE_COOLDOWN_SECONDS=1800
AI_SUMMARY_CHECK_INTERVAL_SECONDS=60
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=20
DEEPSEEK_CACHE_SECONDS=180

KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC_PREFIX=etf_radar
SIGNAL_CONSUMER_GROUP=etf-radar-signal-worker

CLICKHOUSE_ENABLED=true
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=etf_radar
CLICKHOUSE_USER=etf
CLICKHOUSE_PASSWORD=change-me

POSTGRES_ENABLED=true
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=etf_radar
POSTGRES_USER=etf
POSTGRES_PASSWORD=change-me

REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=etf_radar

ALERT_WEBHOOK_URL=

EVENT_CORPUS_ENABLED=true
EVENT_CORPUS_SOURCE_URLS=https://np-listapi.eastmoney.com/comm/web/getNewsByColumns?client=web&biz=web_news_col&column=353&order=1&needInteractData=0&page_index=1&page_size=40&req_trace={timestamp}&fields=code,showTime,title,mediaName,summary,image,url,uniqueUrl,Np_dst&types=1,20
EVENT_CORPUS_CACHE_SECONDS=300
EVENT_CORPUS_MAX_ITEMS=160
